{
  "name": "signalframeux",
  "version": "0.1.0",
  "description": "High-performance design system — FRAME/SIGNAL dual-layer model for Culture Division",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./animation": {
      "import": {
        "types": "./dist/animation.d.mts",
        "default": "./dist/animation.mjs"
      },
      "require": {
        "types": "./dist/animation.d.ts",
        "default": "./dist/animation.cjs"
      }
    },
    "./webgl": {
      "import": {
        "types": "./dist/webgl.d.mts",
        "default": "./dist/webgl.mjs"
      },
      "require": {
        "types": "./dist/webgl.d.ts",
        "default": "./dist/webgl.cjs"
      }
    },
    "./signalframeux.css": "./dist/signalframeux.css"
  },
  "files": [
    "dist",
    "!dist/*.map",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "MIGRATION.md"
  ],
  "sideEffects": [
    "**/*.css",
    "./lib/gsap-core.ts",
    "./lib/gsap-draw.ts",
    "./lib/gsap-flip.ts",
    "./lib/gsap-plugins.ts",
    "./lib/gsap-split.ts"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "registry:build": "shadcn build",
    "build:lib": "tsup && tsx scripts/wrap-tokens-layer.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "prepublishOnly": "pnpm build:lib && npx tsx scripts/verify-tree-shake.ts && npx tsx scripts/verify-bundle-size.ts",
    "docs:generate": "tsx scripts/generate-api-docs.ts",
    "audit:detail-size": "tsx scripts/audit-api-detail-size.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
  "peerDependencies": {
    "next": ">=15.3.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "tailwindcss": ">=4.0.0",
    "three": ">=0.183.0"
  },
  "peerDependenciesMeta": {
    "gsap": {
      "optional": true
    },
    "@gsap/react": {
      "optional": true
    },
    "three": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-link": "3.22.5",
    "@tiptap/pm": "3.22.5",
    "@tiptap/react": "3.22.5",
    "@tiptap/starter-kit": "3.22.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.2",
    "lenis": "^1.1.20",
    "lucide-react": "^0.488.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.0",
    "server-only": "^0.0.1",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/eslintrc": "^3.3.5",
    "@gsap/react": "^2.1.2",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.2",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@storybook/theming": "^8.6.14",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.15.3",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/three": "^0.183.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "chromatic": "^16.2.0",
    "eslint": "^9.25.1",
    "eslint-config-next": "^16.2.3",
    "geist": "^1.7.0",
    "gsap": "^3.14.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lighthouse": "^13.1.0",
    "lint-staged": "^16.4.0",
    "opentype.js": "^1.3.4",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "shadcn": "^4.1.2",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.2",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}
